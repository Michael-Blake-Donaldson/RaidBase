{
  "ci": {
    "collect": {
      "url": [
        "http://127.0.0.1:3000/",
        "http://127.0.0.1:3000/lfg",
        "http://127.0.0.1:3000/squads",
        "http://127.0.0.1:3000/profile/ghosttrace"
      ],
      "startServerCommand": "npm run start",
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.9
          }
        ],
        "largest-contentful-paint": [
          "warn",
          {
            "maxNumericValue": 2500
          }
        ],
        "interaction-to-next-paint": [
          "warn",
          {
            "maxNumericValue": 200
          }
        ],
        "cumulative-layout-shift": [
          "warn",
          {
            "maxNumericValue": 0.1
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
