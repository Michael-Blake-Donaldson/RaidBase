# Local development database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/raidbase?schema=public"

# Environment safety
# In production, keep this as true so startup fails fast on missing required vars.
STRICT_ENV_VALIDATION="false"

# Auth
# Use a long random value in real environments.
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Billing
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""

# Distributed rate limiting (required for production)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
